rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Household data is keyed by SHA-256(token) — unguessable without the secret.
    // Anonymous auth is required so completely unauthenticated clients are blocked.
    // All documents are client-side AES-GCM-256 encrypted; Firestore sees only ciphertext.
    match /households/{householdId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
